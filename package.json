{
  "name": "weavenet-for-copilot",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.4.1",
  "publisher": "huangonce",
  "icon": "resources/icon.png",
  "author": "huangonce",
  "license": "MIT",
  "pricing": "Free",
  "keywords": [
    "copilot",
    "sub2api",
    "openai",
    "claude",
    "anthropic",
    "ai models",
    "model relay",
    "bring your own key"
  ],
  "galleryBanner": {
    "color": "#0b0f16",
    "theme": "dark"
  },
  "homepage": "https://github.com/huangonce/weavenet-for-copilot#readme",
  "bugs": {
    "url": "https://github.com/huangonce/weavenet-for-copilot/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/huangonce/weavenet-for-copilot"
  },
  "engines": {
    "vscode": "^1.116.0",
    "node": ">=24"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "weavenet",
        "displayName": "WeaveNet"
      }
    ],
    "commands": [
      {
        "command": "weavenet-copilot.setRelayKey",
        "title": "%command.setRelayKey%"
      },
      {
        "command": "weavenet-copilot.clearRelayKey",
        "title": "%command.clearRelayKey%"
      },
      {
        "command": "weavenet-copilot.createProfile",
        "title": "%command.createProfile%"
      },
      {
        "command": "weavenet-copilot.addConnection",
        "title": "%command.addConnection%"
      },
      {
        "command": "weavenet-copilot.editConnection",
        "title": "%command.editConnection%"
      },
      {
        "command": "weavenet-copilot.copyConnection",
        "title": "%command.copyConnection%"
      },
      {
        "command": "weavenet-copilot.deleteConnection",
        "title": "%command.deleteConnection%"
      },
      {
        "command": "weavenet-copilot.clearAllConnections",
        "title": "%command.clearAllConnections%"
      },
      {
        "command": "weavenet-copilot.testConnection",
        "title": "%command.testConnection%"
      },
      {
        "command": "weavenet-copilot.manageConnections",
        "title": "%command.manageConnections%"
      },
      {
        "command": "weavenet-copilot.refreshModels",
        "title": "%command.refreshModels%"
      },
      {
        "command": "weavenet-copilot.refreshModelMetadata",
        "title": "%command.refreshModelMetadata%"
      },
      {
        "command": "weavenet-copilot.openSettings",
        "title": "%command.openSettings%"
      },
      {
        "command": "weavenet-copilot.showDebugLog",
        "title": "%command.showDebugLog%"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "weavenet-copilot.activeProfile": {
          "type": "string",
          "default": "",
          "scope": "application",
          "description": "%configuration.activeProfile.description%",
          "deprecationMessage": "%configuration.activeProfile.deprecation%"
        },
        "weavenet-copilot.profiles": {
          "type": "array",
          "default": [],
          "scope": "application",
          "description": "%configuration.profiles.description%",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "name",
              "baseUrl"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
                "description": "Extension-managed stable connection identifier."
              },
              "name": {
                "type": "string"
              },
              "baseUrl": {
                "type": "string"
              },
              "requestHeaders": {
                "type": "object"
              },
              "includeModels": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "excludeModels": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "models": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "id",
                    "route"
                  ],
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "route": {
                      "type": "string",
                      "enum": [
                        "openai",
                        "chatgpt",
                        "claude"
                      ]
                    },
                    "maxInputTokens": {
                      "type": "number",
                      "minimum": 1
                    },
                    "maxOutputTokens": {
                      "type": "number",
                      "minimum": 1
                    },
                    "toolCalling": {
                      "type": "boolean"
                    },
                    "imageInput": {
                      "type": "boolean"
                    },
                    "thinking": {
                      "type": "boolean"
                    },
                    "contextWindows": {
                      "type": "array",
                      "uniqueItems": true,
                      "items": {
                        "type": "number",
                        "minimum": 1
                      }
                    },
                    "openai": {
                      "type": "object",
                      "additionalProperties": false,
                      "description": "%configuration.modelOpenAICapabilities.description%",
                      "properties": {
                        "tokenLimitField": {
                          "type": "string",
                          "enum": [
                            "max_tokens",
                            "max_completion_tokens",
                            "omit"
                          ]
                        },
                        "contextWindow": {
                          "type": "boolean"
                        },
                        "promptCacheKey": {
                          "type": "boolean"
                        },
                        "store": {
                          "type": "boolean"
                        },
                        "strictTools": {
                          "type": "boolean"
                        },
                        "parallelToolCalls": {
                          "type": "boolean"
                        },
                        "developerRole": {
                          "type": "boolean"
                        },
                        "clientRequestId": {
                          "type": "boolean"
                        },
                        "reasoningEfforts": {
                          "type": "array",
                          "uniqueItems": true,
                          "items": {
                            "type": "string",
                            "enum": [
                              "none",
                              "minimal",
                              "low",
                              "medium",
                              "high",
                              "xhigh",
                              "max"
                            ]
                          }
                        },
                        "defaultReasoningEffort": {
                          "type": "string",
                          "enum": [
                            "none",
                            "minimal",
                            "low",
                            "medium",
                            "high",
                            "xhigh",
                            "max"
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "weavenet-copilot.anthropicVersion": {
          "type": "string",
          "default": "2023-06-01",
          "description": "%configuration.anthropicVersion.description%"
        },
        "weavenet-copilot.openaiPromptCaching": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.openaiPromptCaching.description%"
        },
        "weavenet-copilot.openaiPromptCacheKey": {
          "type": "string",
          "default": "",
          "description": "%configuration.openaiPromptCacheKey.description%"
        },
        "weavenet-copilot.claudePromptCaching": {
          "type": "string",
          "enum": [
            "automatic",
            "disabled"
          ],
          "enumDescriptions": [
            "%configuration.claudePromptCaching.automatic%",
            "%configuration.claudePromptCaching.disabled%"
          ],
          "default": "automatic",
          "description": "%configuration.claudePromptCaching.description%"
        },
        "weavenet-copilot.claudePromptCachingTTL": {
          "type": "string",
          "enum": [
            "5m",
            "1h"
          ],
          "default": "5m",
          "description": "%configuration.claudePromptCachingTTL.description%"
        },
        "weavenet-copilot.temperature": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "minimum": 0,
          "maximum": 2,
          "description": "%configuration.temperature.description%"
        },
        "weavenet-copilot.topP": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "minimum": 0,
          "maximum": 1,
          "description": "%configuration.topP.description%"
        },
        "weavenet-copilot.requestTimeoutSeconds": {
          "type": "number",
          "default": 120,
          "minimum": 5,
          "maximum": 300,
          "description": "%configuration.requestTimeoutSeconds.description%"
        },
        "weavenet-copilot.streamIdleTimeoutSeconds": {
          "type": "number",
          "default": 90,
          "minimum": 10,
          "maximum": 600,
          "description": "%configuration.streamIdleTimeoutSeconds.description%"
        },
        "weavenet-copilot.debug": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.debug.description%"
        },
        "weavenet-copilot.modelNamePrefix": {
          "type": "string",
          "default": "WeaveNet",
          "description": "%configuration.modelNamePrefix.description%"
        },
        "weavenet-copilot.includeModels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%configuration.includeModels.description%",
          "deprecationMessage": "%configuration.legacyConnectionField.deprecation%"
        },
        "weavenet-copilot.excludeModels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%configuration.excludeModels.description%",
          "deprecationMessage": "%configuration.legacyConnectionField.deprecation%"
        },
        "weavenet-copilot.maxInputTokens": {
          "type": "number",
          "default": 128000,
          "minimum": 1,
          "description": "%configuration.maxInputTokens.description%"
        },
        "weavenet-copilot.maxOutputTokens": {
          "type": "number",
          "default": 16384,
          "minimum": 1,
          "description": "%configuration.maxOutputTokens.description%"
        },
        "weavenet-copilot.sendMaxTokens": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.sendMaxTokens.description%"
        },
        "weavenet-copilot.supportsToolCalling": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.supportsToolCalling.description%"
        },
        "weavenet-copilot.supportsImageInput": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.supportsImageInput.description%"
        },
        "weavenet-copilot.imageInputModels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%configuration.imageInputModels.description%"
        },
        "weavenet-copilot.disabledImageInputModels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%configuration.disabledImageInputModels.description%"
        },
        "weavenet-copilot.metadataRefreshHours": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "description": "%configuration.metadataRefreshHours.description%"
        },
        "weavenet-copilot.requestHeaders": {
          "type": "object",
          "default": {},
          "description": "%configuration.requestHeaders.description%",
          "deprecationMessage": "%configuration.legacyConnectionField.deprecation%"
        },
        "weavenet-copilot.models": {
          "type": "array",
          "default": [],
          "description": "%configuration.models.description%",
          "deprecationMessage": "%configuration.legacyConnectionField.deprecation%",
          "items": {
            "type": "object",
            "required": [
              "id",
              "route"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "route": {
                "type": "string",
                "enum": [
                  "openai",
                  "chatgpt",
                  "claude"
                ]
              },
              "maxInputTokens": {
                "type": "number",
                "minimum": 1
              },
              "maxOutputTokens": {
                "type": "number",
                "minimum": 1
              },
              "toolCalling": {
                "type": "boolean"
              },
              "imageInput": {
                "type": "boolean"
              },
              "thinking": {
                "type": "boolean"
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true })\"",
    "compile": "npm run clean && tsc -p ./",
    "watch": "npm run clean && tsc -watch -p ./",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "npm run compile && node test/integration/run.cjs",
    "test:watch": "vitest",
    "package:list": "vsce ls",
    "package": "vsce package",
    "publish:marketplace": "vsce publish --skip-duplicate"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
